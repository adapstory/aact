{
  "name": "aact",
  "version": "1.0.0",
  "type": "module",
  "description": "Architecture analysis and compliance tool",
  "bin": {
    "aact": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "homepage": "https://github.com/Byndyusoft/aact#readme",
  "bugs": {
    "url": "https://github.com/Byndyusoft/aact/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Byndyusoft/aact.git"
  },
  "packageManager": "pnpm@9.15.4",
  "files": [
    "dist"
  ],
  "license": "GPL-3.0",
  "author": "Ruslan Safin (Byndyusoft)",
  "scripts": {
    "build": "unbuild",
    "test": "vitest run",
    "lint": "npm run lint:eslint && npm run lint:markdown && npm run lint:prettier",
    "lint:eslint": "eslint .",
    "lint:markdown": "markdownlint --ignore-path ./.gitignore \"./**/*.md\"",
    "lint:prettier": "prettier --ignore-path ./.gitignore --check \"./**/*.{ts,js,json,yaml,yml,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ],
    "*.{ts,js,json,yaml,yml,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@eslint/js": "^9",
    "@types/node": "^20.19.32",
    "eslint": "^9",
    "eslint-plugin-n": "^17",
    "eslint-plugin-simple-import-sort": "^12",
    "eslint-plugin-sonarjs": "^3",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "markdownlint-cli": "0.31.1",
    "prettier": "3.8.1",
    "prettier-plugin-packagejson": "3.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8",
    "unbuild": "^3.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "c12": "4.0.0-beta.2",
    "citty": "^0.2.0",
    "consola": "^3.4.2",
    "plantuml-parser": "0.4.0",
    "valibot": "^1.2.0",
    "yaml": "2.8.2"
  }
}
