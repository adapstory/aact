{
  "name": "aact",
  "version": "3.0.0",
  "type": "module",
  "description": "Architecture analysis and compliance tool",
  "keywords": [
    "architecture",
    "architecture-as-code",
    "plantuml",
    "structurizr",
    "c4-model",
    "architecture-testing",
    "microservices",
    "validation",
    "linter",
    "cli",
    "auto-fix",
    "kubernetes",
    "coupling",
    "cohesion"
  ],
  "bin": {
    "aact": "dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "homepage": "https://github.com/Byndyusoft/aact#readme",
  "bugs": {
    "url": "https://github.com/Byndyusoft/aact/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byndyusoft/aact.git"
  },
  "packageManager": "pnpm@9.15.4",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "GPL-3.0",
  "author": "Ruslan Safin (Byndyusoft)",
  "scripts": {
    "build": "unbuild",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "changelog": "changelogen",
    "release": "changelogen --release --push",
    "knip": "knip",
    "publint": "publint",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --ignore-path ./.gitignore --check \"./**/*.{ts,js,json,yaml,yml,md}\"",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ],
    "*.{ts,js,json,yaml,yml,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^9",
    "@fast-check/vitest": "^0.4.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "changelogen": "^0.6.2",
    "eslint": "^9",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-citty": "^1.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17",
    "eslint-plugin-simple-import-sort": "^12",
    "eslint-plugin-sonarjs": "^3",
    "eslint-plugin-unicorn": "^62.0.0",
    "execa": "^9.6.1",
    "globals": "^17.6.0",
    "husky": "9.1.7",
    "knip": "^6.12.2",
    "lint-staged": "16.2.7",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "publint": "^0.3.20",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.3",
    "unbuild": "^3.0.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "c12": "4.0.0-beta.2",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "jiti": "^2.7.0",
    "pathe": "^2.0.3",
    "plantuml-parser": "0.4.0",
    "valibot": "^1.4.0",
    "yaml": "2.9.0"
  }
}
