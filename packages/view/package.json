{
  "name": "@aact/view",
  "version": "0.0.0",
  "description": "Local architecture workbench for aact — browser-based live viewer of the normalised C4 Model.",
  "type": "module",
  "license": "GPL-3.0",
  "author": "Sergei Volchkov",
  "homepage": "https://github.com/Byndyusoft/aact#readme",
  "bugs": {
    "url": "https://github.com/Byndyusoft/aact/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byndyusoft/aact.git",
    "directory": "packages/view"
  },
  "keywords": [
    "aact",
    "architecture",
    "c4",
    "viewer",
    "workbench"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "aact": "workspace:*"
  },
  "devDependencies": {
    "aact": "workspace:*",
    "typescript": "5.9.3"
  }
}
