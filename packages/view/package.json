{
  "name": "@aact/view",
  "version": "3.0.0-beta.24",
  "description": "Local architecture workbench for aact — browser-based live viewer of the normalised C4 Model.",
  "type": "module",
  "license": "GPL-3.0",
  "author": "Sergei Volchkov",
  "homepage": "https://github.com/Byndyusoft/aact#readme",
  "bugs": {
    "url": "https://github.com/Byndyusoft/aact/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byndyusoft/aact.git",
    "directory": "packages/view"
  },
  "keywords": [
    "aact",
    "architecture",
    "c4",
    "viewer",
    "workbench"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:ui && npm run build:server",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "aact": "workspace:^"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "aact": "workspace:^",
    "svelte": "^5.55.8",
    "typescript": "5.9.3",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@xyflow/svelte": "^1.5.2",
    "chokidar": "^5.0.0",
    "elkjs": "^0.11.1",
    "h3": "2.0.1-rc.22",
    "listhen": "^1.10.0",
    "pathe": "^2.0.3"
  }
}
